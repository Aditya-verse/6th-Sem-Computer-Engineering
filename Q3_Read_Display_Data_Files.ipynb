import pandas as pd
import json
import xml.etree.ElementTree as ET

# 1. Reading and Displaying Text File
text_file_path = 'data/sample.txt'
with open(text_file_path, 'r') as file:
    text_data = file.read()
print("Text File Data:\n", text_data)

# 2. Reading and Displaying CSV File
csv_file_path = 'data/sample.csv'
csv_data = pd.read_csv(csv_file_path)
print("\nCSV File Data:")
print(csv_data)

# 3. Reading and Displaying JSON File
json_file_path = 'data/sample.json'
with open(json_file_path, 'r') as file:
    json_data = json.load(file)
print("\nJSON File Data:\n", json_data)

# 4. Reading and Displaying XML File
xml_file_path = 'data/sample.xml'
tree = ET.parse(xml_file_path)
root = tree.getroot()
print("\nXML File Data:")
for child in root:
    print(child.tag, child.text)